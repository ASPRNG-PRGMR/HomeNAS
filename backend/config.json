  "custom_config": {
    "nas_root": "home_path/nas/nas_storage",
    "jwt_secret": "please_put_something_that_is_actually_hard_to_guess",
    "jwt_expiry_seconds": 86400,
    "admin_username": "admin",
    "admin_password": "admin@change_this"
  }
}
